# .env.example

# Environment variable templates

# ANTHROPIC_API_KEY is required for server-side usage
ANTHROPIC_API_KEY=sk-ant-your-key-here

# NEXT_PUBLIC_API_URL is optional for custom API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Security Note:
# Never commit .env.local to git, as it contains sensitive information that should not be shared.